@prefix : <https://semantica.dev/legal/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Ontology declaration
<https://semantica.dev/legal/ontology#> a owl:Ontology ;
    rdfs:label "Vietnamese Legal Document Ontology"@vi ;
    rdfs:comment "Ontology for Vietnamese legal documents"@vi .

# Classes
:Thing a owl:Class ;
    rdfs:label "Sự vật"@vi ;
    rdfs:comment "Lớp gốc của ontology"@vi .

:ORGANIZATION a owl:Class ;
    rdfs:label "ORGANIZATION"@vi ;
    rdfs:subClassOf :Thing ;
    rdfs:comment "Entity type: ORGANIZATION"@vi .

:LEGAL_TERM a owl:Class ;
    rdfs:label "LEGAL_TERM"@vi ;
    rdfs:subClassOf :Thing ;
    rdfs:comment "Entity type: LEGAL_TERM"@vi .

:LEGAL_REFERENCE a owl:Class ;
    rdfs:label "LEGAL_REFERENCE"@vi ;
    rdfs:subClassOf :Thing ;
    rdfs:comment "Entity type: LEGAL_REFERENCE"@vi .

:PERSON_ROLE a owl:Class ;
    rdfs:label "PERSON_ROLE"@vi ;
    rdfs:subClassOf :Thing ;
    rdfs:comment "Entity type: PERSON_ROLE"@vi .

:PERCENTAGE a owl:Class ;
    rdfs:label "PERCENTAGE"@vi ;
    rdfs:subClassOf :Thing ;
    rdfs:comment "Entity type: PERCENTAGE"@vi .

:MONETARY a owl:Class ;
    rdfs:label "MONETARY"@vi ;
    rdfs:subClassOf :Thing ;
    rdfs:comment "Entity type: MONETARY"@vi .

:DURATION a owl:Class ;
    rdfs:label "DURATION"@vi ;
    rdfs:subClassOf :Thing ;
    rdfs:comment "Entity type: DURATION"@vi .

:ACTION a owl:Class ;
    rdfs:label "ACTION"@vi ;
    rdfs:subClassOf :Thing ;
    rdfs:comment "Entity type: ACTION"@vi .

:CONDITION a owl:Class ;
    rdfs:label "CONDITION"@vi ;
    rdfs:subClassOf :Thing ;
    rdfs:comment "Entity type: CONDITION"@vi .

# Object Properties
:QUẢN_LÝ a owl:ObjectProperty ;
    rdfs:label "QUẢN_LÝ"@vi ;
    rdfs:domain :Thing ;
    rdfs:range :Thing .

:THAM_CHIẾU a owl:ObjectProperty ;
    rdfs:label "THAM_CHIẾU"@vi ;
    rdfs:domain :Thing ;
    rdfs:range :Thing .

